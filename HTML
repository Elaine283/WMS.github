<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>WMS 智慧倉儲管理系統｜流通科技專題</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <script id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-chtml.js"></script>
  <style>
    /* 基礎色系設定 */
    :root { 
      --bg: #fffaf4; --ink: #3d332d; --peach: #ff9f7d; --sakura: #ffb7cf; --caramel: #d7ad79;
    }
    body { font-family: 'Noto Sans TC', sans-serif; background-color: var(--bg); color: var(--ink); margin: 0; }
    
    /* 登入卡片樣式 */
    .login-container { max-width: 400px; margin: 50px auto; padding: 30px; background: white; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); }
    .input-field { width: 100%; padding: 12px; margin: 10px 0; border: 1px solid #ddd; border-radius: 8px; box-sizing: border-box; }
    .btn-login { width: 100%; padding: 12px; background: var(--peach); color: white; border: none; border-radius: 8px; font-weight: bold; cursor: pointer; }
    .social-btn { width: 48%; padding: 10px; margin-top: 10px; border: 1px solid #ddd; border-radius: 8px; cursor: pointer; }
    
    /* 列印專用樣式 */
    @media print { .no-print { display: none; } }
  </style>
</head>
<body>

  <div id="login-page" class="login-container">
    <h2 style="text-align: center;">系統登入</h2>
    <input type="email" class="input-field" placeholder="企業電子郵件">
    <input type="password" class="input-field" placeholder="安全存取密碼">
    <label><input type="checkbox"> 記住我</label>
    <button class="btn-login" onclick="showApp()">安全登入</button>
    <div style="text-align: center; margin-top: 15px;">
      <button class="social-btn">Google</button>
      <button class="social-btn">Microsoft</button>
    </div>
  </div>

  <div id="app-content" style="display: none;">
    <header style="padding: 20px; text-align: right;" class="no-print">
      <button onclick="window.print()">🖨️ 列印報告</button>
    </header>

    <main style="padding: 20px;">
      <h1>iWMS 智慧倉儲系統概覽</h1>
      
      <section id="calculator">
        <h2>EOQ 數據驅動決策</h2>
        <div id="eoq-math">$$EOQ = \sqrt{\frac{2DS}{H}}$$</div>
        <input type="number" id="D" placeholder="年度需求 D">
        <input type="number" id="S" placeholder="訂購成本 S">
        <input type="number" id="H" placeholder="持有成本 H">
        <button onclick="calc()">計算結果</button>
        <div id="result"></div>
      </section>

      <section>
        <h2>相關技術說明</h2>
        <iframe width="560" height="315" src="https://www.youtube.com/embed/GI5jxp4rtEs" allowfullscreen></iframe>
      </section>
    </main>
  </div>

  <script>
    function showApp() {
      document.getElementById('login-page').style.display = 'none';
      document.getElementById('app-content').style.display = 'block';
    }

    function calc() {
      const D = document.getElementById('D').value;
      const S = document.getElementById('S').value;
      const H = document.getElementById('H').value;
      const eoq = Math.sqrt((2 * D * S) / H);
      document.getElementById('result').innerHTML = `計算結果：最適訂購量為 ${eoq.toFixed(2)} 件`;
    }
  </script>
</body>
</html>
