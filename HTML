<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>iWMS 2026 | 智慧零售選物物流中心</title>
<script src="https://cdn.tailwindcss.com"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>
<script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
<script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
<script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
<style>
body { background-color: #FAF7F2; color: #78350F; font-family: 'PingFang TC', sans-serif; }
.luxury-glass { background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(20px); }
.card-style { background: #FFFFFF; border: 1px solid rgba(180, 83, 9, 0.1); box-shadow: 0 10px 25px rgba(0,0,0,0.03); }
input { border: 1px solid #E2E8F0; border-radius: 8px; padding: 10px; width: 100%; }
@media print { .no-print { display: none !important; } }
</style>
</head>
<body class="w-full overflow-x-hidden">

<div class="w-full bg-orange-900 text-white px-4 py-2 flex justify-between items-center text-[10px] no-print">
    <span>iWMS 2026 智慧物流管理門戶</span>
    <button onclick="window.print()" class="border border-white/30 px-2 py-0.5 rounded hover:bg-white/20">🖨️ 列印報告</button>
</div>

<div id="login-root" class="py-12 px-4"></div>

<main class="w-full max-w-2xl mx-auto px-4 py-8 space-y-12">
    <section class="card-style p-8 rounded-3xl">
        <h1 class="text-3xl font-black text-orange-900 mb-4">iWMS 智慧倉儲決策系統</h1>
        <p class="text-sm leading-relaxed text-amber-900/80">
            結合 AI 互動與庫存最佳化演算法，將傳統物流中心轉型為數據驅動的智能決策大腦。
        </p>
    </section>

    <section class="card-style p-8 rounded-3xl">
        <h2 class="text-xl font-bold mb-6 text-orange-900">最佳化模擬計算機</h2>
        <div class="grid grid-cols-2 gap-4">
            <div><label class="text-[10px] font-bold">年需求(D)</label><input type="number" id="valD" value="5000" oninput="runModel()"></div>
            <div><label class="text-[10px] font-bold">訂購成本(S)</label><input type="number" id="valS" value="50" oninput="runModel()"></div>
            <div><label class="text-[10px] font-bold">持有成本(H)</label><input type="number" id="valH" value="2" oninput="runModel()"></div>
            <div><label class="text-[10px] font-bold">安全庫存(SS)</label><input type="number" id="valSS" value="100" oninput="runModel()"></div>
        </div>
        <div class="mt-6 text-center py-4 bg-orange-50 rounded-xl">
            <span class="text-sm font-bold block">最佳訂購量(Q*)</span>
            <span id="resQ" class="text-3xl font-black text-orange-600">--</span>
        </div>
    </section>

    <section class="card-style p-6 rounded-3xl">
        <canvas id="myChart" class="h-64"></canvas>
    </section>
</main>

<script type="text/babel">
function Login() {
    return (
        <div class="card-style p-8 rounded-3xl max-w-md mx-auto">
            <h2 class="text-center font-bold text-orange-900 mb-6">安全認證入口</h2>
            <div class="space-y-4">
                <input type="email" placeholder="企業電子郵件" />
                <input type="password" placeholder="安全密碼" />
                <button class="w-full bg-orange-800 text-white py-3 rounded-xl font-bold">登入系統</button>
                <div class="grid grid-cols-2 gap-2 text-[10px]">
                    <button class="border py-2 rounded-lg">Google 登入</button>
                    <button class="border py-2 rounded-lg">Microsoft 登入</button>
                </div>
            </div>
        </div>
    );
}
ReactDOM.createRoot(document.getElementById('login-root')).render(<Login />);
</script>

<script>
let chart;
function runModel() {
    const D = parseFloat(document.getElementById('valD').value) || 0;
    const S = parseFloat(document.getElementById('valS').value) || 0;
    const H = parseFloat(document.getElementById('valH').value) || 1;
    const Q = Math.sqrt((2 * D * S) / H);
    document.getElementById('resQ').innerText = Math.round(Q);
    
    if (chart) chart.destroy();
    chart = new Chart(document.getElementById('myChart'), {
        type: 'line',
        data: { labels: ['T1', 'T2', 'T3', 'T4', 'T5'], datasets: [{ data: [100, 80, 60, 40, 120], borderColor: '#D97706', tension: 0.4 }] },
        options: { responsive: true, plugins: { legend: { display: false } } }
    });
}
runModel();
</script>
</body>
</html>
