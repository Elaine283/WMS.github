<script>
let trendChart, pieChart;
const ctxTrend = document.getElementById('trendChart').getContext('2d');
const ctxPie = document.getElementById('pieChart').getContext('2d');

function calculateEngine() {
const D = parseFloat(document.getElementById('inputD').value) || 0;
const S = parseFloat(document.getElementById('inputS').value) || 0;
const H = parseFloat(document.getElementById('inputH').value) || 1;
const SS = parseFloat(document.getElementById('inputSS').value) || 0;

// 計算最佳 EOQ
const Q = Math.sqrt((2 * D * S) / H);
const optimalQ = Math.round(Q) || 1;

// 計算再訂購點 ROP (假設固定前置時間 8 天，日需求 = D / 365)
const ROP = Math.round((D / 365) * 8) + SS;

document.getElementById('outputQ').innerText = optimalQ;
document.getElementById('outputROP').innerText = ROP;

// 1. 生成動態鋸齒趨勢圖數據
const trendLabels = [];
const trendData = [];
let currentStock = optimalQ + SS;

for (let i = 0; i <= 20; i++) {
trendLabels.push('T+' + i);
trendData.push(currentStock);
currentStock -= (optimalQ / 5);
if (currentStock < SS) {
currentStock = optimalQ + SS;
}
}

if (trendChart) trendChart.destroy();
trendChart = new Chart(ctxTrend, {
type: 'line',
data: {
labels: trendLabels,
datasets: [{
label: '即時庫存量',
data: trendData,
borderColor: '#DB2777',
backgroundColor: 'rgba(219, 39, 119, 0.03)',
borderWidth: 1.5,
pointRadius: 1,
fill: true,
tension: 0
}]
},
options: {
responsive: true,
maintainAspectRatio: false,
plugins: { title: { display: true, text: '庫存水平週期性波動趨勢 (安全庫存鋸齒波)', color: '#92400E', font: { size: 10, weight: 'bold' } }, legend: { display: false } },
scales: { y: { min: 0, ticks: { font: { size: 8 } } }, x: { ticks: { display: false } } }
}
});

// 2. 生成成本結構環狀比例圖
const holdingCostTotal = (optimalQ / 2) * H;
const orderingCostTotal = (D / optimalQ) * S;

if (pieChart) pieChart.destroy();
pieChart = new Chart(ctxPie, {
type: 'doughnut',
data: {
labels: ['持有總成本', '訂購總成本'],
datasets: [{
data: [holdingCostTotal, orderingCostTotal],
backgroundColor: ['#FFD6D6', '#FEF3C7'],
borderColor: ['#DB2777', '#D97706'],
borderWidth: 1
}]
},
options: {
responsive: true,
maintainAspectRatio: false,
plugins: { title: { display: true, text: '最佳化持有與訂購成本平衡比例', color: '#92400E', font: { size: 10, weight: 'bold' } }, legend: { position: 'right', labels: { boxWidth: 10, font: { size: 9 }, color: '#92400E' } } }
}
});
}

// 初始加載計算
setTimeout(() => {
calculateEngine();
}, 600);
</script>

