<button class="
  /* 基礎形狀與字體 */
  px-6 py-3 rounded-2xl font-bold text-toy-dark text-sm tracking-wide
  /* 顏色與視覺特徵 */
  bg-toy-yellow border-3 border-toy-dark
  /* 核心：物理硬陰影與絲滑平移 (Duration 要快，才有機械感) */
  [box-shadow:4px_4px_0px_#073B4C] transition-all duration-75 select-none
  /* 互動態：Hover 微微放大，Active 壓下去 */
  hover:-translate-y-0.5 hover:[box-shadow:6px_6px_0px_#073B4C]
  active:translate-x-1 active:translate-y-1 active:[box-shadow:0px_0px_0px_#073B4C]
">
  📦 確認入庫
</button>
